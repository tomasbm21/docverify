# === LLM Provider ===
# Options: ollama | anthropic | gemini
LLM_PROVIDER=ollama

# Ollama (local) — default, no API key needed
OLLAMA_BASE_URL=http://192.168.1.142:11434
OLLAMA_MODEL=llama3

# Anthropic (cloud)
ANTHROPIC_API_KEY=

# Gemini (cloud, optional — MUST be paid/no-train key)
GEMINI_API_KEY=

# === Email ===
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=tomasborja21@gmail.com

# IMAP (for inbox polling — Gmail requires App Password)
EMAIL_HOST=imap.gmail.com
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your-app-password
